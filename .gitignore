.DS_Store
.idea/
__pycache__/
*.pyc
.pytest_cache/
.venv/
data_local/
.tmp/
logs/
# Large or untracked exploratory outputs under reports/. Tracked artifacts
# (vet_sheet.pdf/png, candidates.parquet, meta.json) are committed selectively;
# the gitignored entries below are the regenerable bulk.
reports/exploratory/
# Stage 2 BLS periodograms are large (~1.5 MB/target) and regenerable from
# the HLSP FITS; keep candidates.parquet and meta.json instead.
reports/stage2_search/wd1856_bls/**/periodograms/
reports/stage2_search/wd1856_bls/**/targets/*/periodograms/
# 122 MB of top-N vet sheets from S56 production — regenerable from PDO via
# scripts/stage2_search/filter_wd_candidates.py + sector_run --include-tics.
reports/stage2_search/wd1856_bls_s56_top30/
# LEO-Vetter and TGLC-vs-QLP comparison outputs — regenerable; keep MANIFEST/parquet only
reports/stage5_validation/leo_vetter_s56_*/vet_reports/
reports/stage1_lightcurves/tglc_vs_qlp_s94plus/
reports/stage1_lightcurves/qc_pdf/

# Claude Code state
.claude/

# Python build artifacts
src/*.egg-info/
