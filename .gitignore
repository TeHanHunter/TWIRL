.DS_Store
.idea/
__pycache__/
*.pyc
.pytest_cache/
.venv/
data_local/
.tmp/
logs/
# Large or untracked exploratory outputs under reports/. Tracked artifacts
# (vet_sheet.pdf/png, candidates.parquet, meta.json) are committed selectively;
# the gitignored entries below are the regenerable bulk.
reports/exploratory/
# Stage 2 BLS periodograms are large (~1.5 MB/target) and regenerable from
# the HLSP FITS; keep candidates.parquet and meta.json instead.
reports/stage2_search/wd1856_bls/**/periodograms/
reports/stage2_search/wd1856_bls/**/targets/*/periodograms/
# 122 MB of top-N vet sheets from S56 production — regenerable from PDO via
# scripts/stage2_search/filter_wd_candidates.py + sector_run --include-tics.
reports/stage2_search/wd1856_bls_s56_top30/
# LEO-Vetter and TGLC-vs-QLP comparison outputs — regenerable; keep MANIFEST/parquet only
reports/stage5_validation/**/vet_reports/
reports/stage5_validation/**/vet_reports
reports/stage5_validation/**/twirl_vet_sheets/
reports/stage5_validation/**/twirl_vet_sheets*/
reports/stage5_validation/leo_vetter_s56_*/vet_reports/
reports/stage5_validation/**/chunks/
reports/stage5_validation/**/chunk_ids/
# Regenerable ML payloads. Commit compact summaries, labels, and selected
# paper-facing figures explicitly; keep tensors/checkpoints/score chunks on
# local or ORCD storage.
reports/stage5_validation/**/cnn_tensors*/
reports/stage5_validation/**/cnn_teacher*/
reports/stage5_validation/**/eb_cnn_miner/
reports/stage5_validation/**/candidate_pool/
reports/stage5_validation/**/score_chunks/
reports/stage5_validation/**/*.zip
# These local queue roots contain a deliberately tracked compact checkpoint;
# ignore additional regenerated audits, split tables, screenshots, and package
# copies. Use `git add -f` when a new compact artifact is intentionally kept.
reports/stage5_validation/s56_1k_predetrend_small_pair_200k_review_queue_pdo/**
reports/stage5_validation/s56_eb_miner/**
reports/stage5_validation/s56_eb_miner_adp_only/**
reports/stage5_validation/s56_franklin_real5k_handoff/**
reports/stage5_validation/s56_franklin_real5k_handoff_download/**
reports/stage5_validation/s56_mixed_teacher_queue_pdo/**
reports/stage5_validation/s56_label_adjudication_real343/**
reports/stage5_validation/s56_recovery50_teacher_queue/**
reports/stage5_validation/s56_recovery50_teacher_queue_2k/**
reports/stage5_validation/s56_recovery50_teacher_queue_next1k/**
reports/stage3_injections/**/*.h5
reports/stage3_injections/**/*.fits
reports/stage3_injections/**/*.npy
reports/stage1_lightcurves/tglc_vs_qlp_s94plus/
reports/stage1_lightcurves/qc_pdf/
reports/stage1_lightcurves/qc_precision/

# Local presentation editing buffers and Keynote recovery copies. Final talk
